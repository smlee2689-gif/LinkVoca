# 이 파일에는 실제 키나 사용자 데이터를 입력하지 않습니다.
# EXPO_PUBLIC_* 값은 앱 번들에 노출되므로 비밀값으로 취급할 수 없습니다.

# 공개 가능한 Supabase 클라이언트 설정(동기화 단계에서 사용)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# 공개 클라이언트 식별자 또는 서버 프록시 URL(제공자 선정 후 이름 확정)
EXPO_PUBLIC_IMAGE_SEARCH_PROVIDER=
EXPO_PUBLIC_IMAGE_SEARCH_PROXY_URL=
EXPO_PUBLIC_OCR_PROXY_URL=
EXPO_PUBLIC_AI_IMAGE_PROXY_URL=

# 아래 비밀값은 모바일 앱에 주입하지 않고 서버/Edge Function 환경에서만 사용
# OCR_PROVIDER_SECRET_KEY=
# IMAGE_SEARCH_SECRET_KEY=
# AI_IMAGE_SECRET_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
